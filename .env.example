# Application
APP_ENV=development
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://chiefly:chiefly@localhost:5432/chiefly

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-telegram-chat-id-here

# Google
GOOGLE_CREDENTIALS_FILE=/app/credentials/google_credentials.json
GOOGLE_TASKS_INBOX_LIST_ID=your-inbox-tasklist-id-here

# LLM
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_API_KEY=your-llm-api-key-here

# Polling & Scheduling
INBOX_POLL_INTERVAL_SECONDS=60
DAILY_REVIEW_CRON=0 9 * * *
TIMEZONE=Europe/Moscow
