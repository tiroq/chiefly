# Application
APP_ENV=development
LOG_LEVEL=INFO

# Database
DB_PORT=5433
DATABASE_URL=postgresql+asyncpg://chiefly:chiefly@localhost:5433/chiefly

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-telegram-chat-id-here

# Google
GOOGLE_CREDENTIALS_FILE=/app/credentials/google_credentials.json
GOOGLE_TASKS_DEFAULT_TASKLIST_ID=your-default-tasklist-id-here
# Legacy: GOOGLE_TASKS_INBOX_LIST_ID is also accepted as fallback

# LLM
# Supported providers: openai, ollama, github_models
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_API_KEY=your-llm-api-key-here
LLM_BASE_URL=

# For GitHub Models: set LLM_PROVIDER=github_models, LLM_API_KEY=<your-github-pat>
# Model IDs use publisher/model format, e.g. openai/gpt-4o
# Run `python scripts/setup_github_models.py` for interactive setup

# Multi-model (optional, requires LLM_AUTO_MODE=true)
LLM_FAST_MODEL=
LLM_QUALITY_MODEL=
LLM_FALLBACK_MODEL=
LLM_AUTO_MODE=false

# Rate Limiting (token bucket per provider, bypasses Ollama)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_CAPACITY=10
RATE_LIMIT_REFILL_AMOUNT=1
RATE_LIMIT_REFILL_INTERVAL_SECONDS=30

# Polling & Scheduling
SYNC_INTERVAL_SECONDS=60
# Legacy: INBOX_POLL_INTERVAL_SECONDS is also accepted as fallback
DAILY_REVIEW_CRON=0 9 * * *
PROJECT_SYNC_CRON=0 * * * *
TIMEZONE=Europe/Moscow

# Admin Panel (internal only)
ADMIN_HOST=127.0.0.1
ADMIN_PORT=8001

# Mini App
MINI_APP_URL=https://chiefly.tiroq.dev
